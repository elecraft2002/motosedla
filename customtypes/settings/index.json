{
  "id": "settings",
  "label": "Settings",
  "format": "custom",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "siteTitle": {
        "type": "StructuredText",
        "config": {
          "label": "Site Title",
          "placeholder": "Title of the site",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      }
    },
    "Currency": {
      "currencies": {
        "type": "Group",
        "config": {
          "label": "Currencies",
          "repeat": true,
          "fields": {
            "currency_name": {
              "type": "Text",
              "config": {
                "label": "Currency Name",
                "placeholder": "CZK"
              }
            },
            "currency_image": {
              "type": "Image",
              "config": {
                "label": "Currency Image",
                "constraint": {},
                "thumbnails": [
                  {
                    "name": "small",
                    "width": 64,
                    "height": 64
                  }
                ]
              }
            },
            "currency_course": {
              "type": "Number",
              "config": {
                "label": "Currency Course",
                "placeholder": "Přepočet z výchozí (CZK)"
              }
            }
          }
        }
      }
    }
  }
}
