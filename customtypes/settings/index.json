{
  "id": "settings",
  "label": "Settings",
  "format": "custom",
  "repeatable": false,
  "status": true,
  "json": {
    "Main": {
      "siteTitle": {
        "type": "StructuredText",
        "config": {
          "label": "Site Title",
          "placeholder": "Title of the site",
          "allowTargetBlank": false,
          "single": "heading1"
        }
      },
      "show_products_in_subcategories": {
        "type": "Boolean",
        "config": {
          "label": "Show products in subcategories",
          "placeholder_false": "false",
          "placeholder_true": "true",
          "default_value": true
        }
      },
      "site_logo": {
        "type": "Image",
        "config": {
          "label": "Site logo",
          "constraint": {},
          "thumbnails": [
            { "name": "small", "width": 100, "height": null },
            { "name": "icon", "width": 64, "height": 64 }
          ]
        }
      }
    },
    "Currency": {
      "currency_name": {
        "type": "Text",
        "config": { "label": "Currency Name", "placeholder": "" }
      },
      "currency_image": {
        "type": "Image",
        "config": {
          "label": "Currency Image",
          "constraint": {},
          "thumbnails": [{ "name": "Small", "width": 64, "height": 64 }]
        }
      },
      "currency_course": {
        "type": "Number",
        "config": { "label": "Currency Course", "placeholder": "" }
      }
    }
  }
}
